# Copy this file to .env and fill in your settings

# Ollama server (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest

# STT — local faster-whisper model size: tiny, base, small, medium, large-v3
STT_MODEL_SIZE=base

# TTS — macOS 'say' voice (run 'say -v ?' to list voices)
TTS_VOICE=Alex
TTS_RATE=175

# Audio
SAMPLE_RATE=16000
CHANNELS=1
RECORD_SECONDS=5
